{
  "hosting": {
    "public": "build",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "redirects": [
      {
        "source": "/nooklist/:path*",
        "destination": "https://nooklist.web.app/:path*",
        "type": 301
      },
      {
        "source": "/bnstool/:path*",
        "destination": "https://bnstool.web.app/:path*",
        "type": 301
      }
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}

